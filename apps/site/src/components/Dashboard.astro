---
// Dashboard.astro - Simulated Live Dashboard UI
const currentPath = Astro.url.pathname;
const isCs = currentPath.startsWith('/cs') || currentPath === '/cs';

const t = isCs ? {
  previewTitle: 'Blood Kings - Náhled Administrace',
  simulated: 'SIMULOVANÁ DATA',
  monitors: 'Monitory',
  active: 'Aktivní',
  sslExpiry: 'Expirace',
  sslValid: 'Platný',
  totalUptime: 'Celková Dostupnost',
  uptimeSub: '↑ 0.002% za 30 dní',
  avgLatency: 'Průměrná Latence',
  latencySub: 'Globální průměr',
  monitoredAgents: 'Monitorované Agenty',
  agentsSub: 'Všechny online',
  responseTimeTitle: 'Odezva (posledních 30 minut)',
  serverStatusTitle: 'Stav Centrálního Serveru',
  cpuLoad: 'CPU zátěž',
  ramUsage: 'Využití RAM',
  diskStorage: 'Disk Storage',
  auditLogTitle: 'Audit Log incidentů',
  allSystemsOperational: 'Vše v pořádku'
} : {
  previewTitle: 'Blood Kings - Dashboard Preview',
  simulated: 'SIMULATED DATA',
  monitors: 'Monitors',
  active: 'Active',
  sslExpiry: 'Expires',
  sslValid: 'Valid',
  totalUptime: 'Overall Uptime',
  uptimeSub: '↑ 0.002% in last 30d',
  avgLatency: 'Average Latency',
  latencySub: 'Global average',
  monitoredAgents: 'Monitored Agents',
  agentsSub: 'All online',
  responseTimeTitle: 'Response Time (last 30 minutes)',
  serverStatusTitle: 'Central Server Resource Health',
  cpuLoad: 'CPU Load',
  ramUsage: 'RAM Usage',
  diskStorage: 'Disk Storage',
  auditLogTitle: 'Incident Audit Log',
  allSystemsOperational: 'All systems operational'
};
---

<div class="dashboard-card card card-glow">
  <div class="dashboard-topbar">
    <div class="dash-window-buttons">
      <span></span><span></span><span></span>
    </div>
    <div class="dash-window-title">{t.previewTitle}</div>
    <div class="dash-live-badge">
      <span class="live-dot pulse"></span>
      {t.simulated}
    </div>
  </div>

  <div class="dashboard-grid">
    <!-- Sidebar: Monitors Status List -->
    <aside class="dash-sidebar">
      <div class="sidebar-header">
        <h4>{t.monitors}</h4>
        <span class="count-badge">5 {t.active}</span>
      </div>
      <ul class="monitor-list">
        <li class="monitor-item">
          <div class="monitor-status-info">
            <span class="indicator green"></span>
            <div class="monitor-meta">
              <span class="monitor-name">API Europe</span>
              <span class="monitor-details">HTTPS • bloodkings.eu</span>
            </div>
          </div>
          <div class="monitor-stats">
            <span class="latency">23 ms</span>
            <span class="uptime">99.999%</span>
          </div>
        </li>
        <li class="monitor-item">
          <div class="monitor-status-info">
            <span class="indicator green"></span>
            <div class="monitor-meta">
              <span class="monitor-name">API USA</span>
              <span class="monitor-details">HTTPS • us-node.bloodkings.eu</span>
            </div>
          </div>
          <div class="monitor-stats">
            <span class="latency">45 ms</span>
            <span class="uptime">99.995%</span>
          </div>
        </li>
        <li class="monitor-item">
          <div class="monitor-status-info">
            <span class="indicator green"></span>
            <div class="monitor-meta">
              <span class="monitor-name">API Asia</span>
              <span class="monitor-details">HTTPS • sg-node.bloodkings.eu</span>
            </div>
          </div>
          <div class="monitor-stats">
            <span class="latency">168 ms</span>
            <span class="uptime">99.954%</span>
          </div>
        </li>
        <li class="monitor-item">
          <div class="monitor-status-info">
            <span class="indicator green"></span>
            <div class="monitor-meta">
              <span class="monitor-name">SSL Certifikát</span>
              <span class="monitor-details">{t.sslExpiry} • bloodkings.eu</span>
            </div>
          </div>
          <div class="monitor-stats">
            <span class="latency alert-green">{isCs ? "123 dnů" : "123 days"}</span>
            <span class="uptime">{t.sslValid}</span>
          </div>
        </li>
        <li class="monitor-item">
          <div class="monitor-status-info">
            <span class="indicator green"></span>
            <div class="monitor-meta">
              <span class="monitor-name">IPv6 Gateway</span>
              <span class="monitor-details">PING • ipv6.bloodkings.eu</span>
            </div>
          </div>
          <div class="monitor-stats">
            <span class="latency">11 ms</span>
            <span class="uptime">100.00%</span>
          </div>
        </li>
      </ul>
    </aside>

    <!-- Main Section: Charts and Resources -->
    <section class="dash-main">
      <div class="stats-overview-grid">
        <div class="stat-box">
          <span class="stat-title">{t.totalUptime}</span>
          <span class="stat-value text-gradient">99.987%</span>
          <span class="stat-sub green">{t.uptimeSub}</span>
        </div>
        <div class="stat-box">
          <span class="stat-title">{t.avgLatency}</span>
          <span class="stat-value" id="avg-latency-display">24.5 ms</span>
          <span class="stat-sub">{t.latencySub}</span>
        </div>
        <div class="stat-box">
          <span class="stat-title">{t.monitoredAgents}</span>
          <span class="stat-value">12 / 12</span>
          <span class="stat-sub green">{t.agentsSub}</span>
        </div>
      </div>

      <!-- Live Waveform Chart -->
      <div class="chart-container">
        <div class="chart-header">
          <h5>{t.responseTimeTitle}</h5>
          <span class="chart-legend"><span class="legend-dot bg-accent"></span>Odezva (ms)</span>
        </div>
        <div class="chart-svg-wrapper">
          <svg viewBox="0 0 600 180" class="chart-svg">
            <!-- Grid Lines -->
            <line x1="0" y1="30" x2="600" y2="30" stroke="var(--border-color)" stroke-dasharray="4,4" />
            <line x1="0" y1="80" x2="600" y2="80" stroke="var(--border-color)" stroke-dasharray="4,4" />
            <line x1="0" y1="130" x2="600" y2="130" stroke="var(--border-color)" stroke-dasharray="4,4" />
            
            <!-- Latency Waveform Graph Area -->
            <path d="M 0 100 Q 50 80, 100 110 T 200 90 T 300 120 T 400 70 T 500 100 T 600 85" fill="none" stroke="var(--accent-color)" stroke-width="3" id="latency-path" />
            <path d="M 0 100 Q 50 80, 100 110 T 200 90 T 300 120 T 400 70 T 500 100 T 600 85 L 600 180 L 0 180 Z" fill="url(#chart-gradient)" opacity="0.1" id="latency-area" />
            
            <!-- Pulsing Point on graph -->
            <circle cx="600" cy="85" r="5" fill="var(--accent-color)" />
            <circle cx="600" cy="85" r="10" fill="none" stroke="var(--accent-color)" stroke-dasharray="2" class="pulse" />
            
            <defs>
              <linearGradient id="chart-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="var(--accent-color)" />
                <stop offset="100%" stop-color="var(--accent-color)" stop-opacity="0" />
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>

      <!-- Resource Usage Gauges -->
      <div class="resources-container">
        <h5>{t.serverStatusTitle}</h5>
        <div class="gauges-grid">
          <!-- CPU Ring -->
          <div class="gauge-item">
            <div class="gauge-ring-wrapper">
              <svg viewBox="0 0 100 100" class="gauge-svg">
                <circle cx="50" cy="50" r="40" class="gauge-bg" />
                <circle cx="50" cy="50" r="40" class="gauge-fill" stroke-dasharray="251.2" stroke-dashoffset="205" id="cpu-gauge" />
              </svg>
              <span class="gauge-text" id="cpu-text">18%</span>
            </div>
            <span class="gauge-label">{t.cpuLoad}</span>
          </div>

          <!-- Memory Ring -->
          <div class="gauge-item">
            <div class="gauge-ring-wrapper">
              <svg viewBox="0 0 100 100" class="gauge-svg">
                <circle cx="50" cy="50" r="40" class="gauge-bg" />
                <circle cx="50" cy="50" r="40" class="gauge-fill" stroke-dasharray="251.2" stroke-dashoffset="115" id="ram-gauge" />
              </svg>
              <span class="gauge-text" id="ram-text">54%</span>
            </div>
            <span class="gauge-label">{t.ramUsage}</span>
          </div>

          <!-- Disk Space Ring -->
          <div class="gauge-item">
            <div class="gauge-ring-wrapper">
              <svg viewBox="0 0 100 100" class="gauge-svg">
                <circle cx="50" cy="50" r="40" class="gauge-bg" />
                <circle cx="50" cy="50" r="40" class="gauge-fill" stroke-dasharray="251.2" stroke-dashoffset="148" id="disk-gauge" />
              </svg>
              <span class="gauge-text" id="disk-text">41%</span>
            </div>
            <span class="gauge-label">{t.diskStorage}</span>
          </div>
        </div>
      </div>
      
      <!-- Incident / Event Log -->
      <div class="event-log">
        <div class="event-header">
          <h5>{t.auditLogTitle}</h5>
          <span class="status-indicator-log"><span class="green-dot"></span>{t.allSystemsOperational}</span>
        </div>
        <div class="event-scroller">
          <ul class="event-list" id="dashboard-logs">
            <li class="event-log-item"><span class="log-time">14:45:00</span> <span class="log-tag tag-success">OK</span> {isCs ? "Kontrola API Europe proběhla úspěšně" : "Check of API Europe completed successfully"} (23 ms)</li>
            <li class="event-log-item"><span class="log-time">14:44:32</span> <span class="log-tag tag-success">OK</span> {isCs ? "Kontrola API USA proběhla úspěšně" : "Check of API USA completed successfully"} (45 ms)</li>
            <li class="event-log-item"><span class="log-time">14:44:11</span> <span class="log-tag tag-success">OK</span> {isCs ? "Certifikát pro doménu bloodkings.eu je platný" : "SSL certificate for bloodkings.eu is valid"}</li>
            <li class="event-log-item"><span class="log-time">14:43:55</span> <span class="log-tag tag-success">OK</span> {isCs ? "Kontrola IPv6 Gateway proběhla úspěšně" : "Check of IPv6 Gateway completed successfully"} (11 ms)</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</div>

<script>
  // Simple micro-fluctuations to simulate live dashboard updates
  let currentCpu = 18;
  let currentRam = 54;
  let currentLatency = 24.5;
  const cpuFill = document.getElementById('cpu-gauge');
  const ramFill = document.getElementById('ram-gauge');
  const cpuText = document.getElementById('cpu-text');
  const ramText = document.getElementById('ram-text');
  const latencyDisplay = document.getElementById('avg-latency-display');
  const logsList = document.getElementById('dashboard-logs');

  const updateDashboard = () => {
    // 1. CPU fluctuation
    currentCpu = Math.max(10, Math.min(80, currentCpu + Math.floor(Math.random() * 7) - 3));
    const cpuOffset = 251.2 - (251.2 * currentCpu) / 100;
    if (cpuFill) cpuFill.style.strokeDashoffset = cpuOffset.toString();
    if (cpuText) cpuText.textContent = `${currentCpu}%`;

    // 2. RAM fluctuation
    currentRam = Math.max(50, Math.min(60, currentRam + Math.floor(Math.random() * 3) - 1));
    const ramOffset = 251.2 - (251.2 * currentRam) / 100;
    if (ramFill) ramFill.style.strokeDashoffset = ramOffset.toString();
    if (ramText) ramText.textContent = `${currentRam}%`;

    // 3. Latency display updates
    currentLatency = Number((currentLatency + (Math.random() * 2 - 1)).toFixed(1));
    if (currentLatency < 18) currentLatency = 18;
    if (currentLatency > 30) currentLatency = 30;
    if (latencyDisplay) latencyDisplay.textContent = `${currentLatency} ms`;

    // 4. Update SVG path graph values slightly
    const path = document.getElementById('latency-path');
    const area = document.getElementById('latency-area');
    if (path && area) {
      // Modify wave coordinates slightly to simulate live chart progression
      const rand1 = 80 + Math.floor(Math.random() * 15) - 7;
      const rand2 = 110 + Math.floor(Math.random() * 15) - 7;
      const rand3 = 90 + Math.floor(Math.random() * 15) - 7;
      const rand4 = 120 + Math.floor(Math.random() * 15) - 7;
      const rand5 = 70 + Math.floor(Math.random() * 15) - 7;
      const rand6 = 100 + Math.floor(Math.random() * 15) - 7;
      const newD = `M 0 100 Q 50 ${rand1}, 100 ${rand2} T 200 ${rand3} T 300 ${rand4} T 400 ${rand5} T 500 ${rand6} T 600 85`;
      path.setAttribute('d', newD);
      area.setAttribute('d', `${newD} L 600 180 L 0 180 Z`);
    }

    // 5. Append random success log entries
    if (logsList && Math.random() > 0.7) {
      const times = new Date().toLocaleTimeString('cs-CZ');
      const monitors = ['API Europe', 'API USA', 'IPv6 Gateway', 'API Asia'];
      const pickedMonitor = monitors[Math.floor(Math.random() * monitors.length)];
      const ping = pickedMonitor === 'API Asia' ? 150 + Math.floor(Math.random() * 30) : 10 + Math.floor(Math.random() * 25);
      
      const isCs = window.location.pathname.startsWith('/cs') || window.location.pathname === '/cs';
      const newLog = document.createElement('li');
      newLog.className = 'event-log-item';
      newLog.innerHTML = `<span class="log-time">${times}</span> <span class="log-tag tag-success">OK</span> ${
        isCs ? `Kontrola ${pickedMonitor} proběhla úspěšně` : `Check of ${pickedMonitor} completed successfully`
      } (${ping} ms)`;
      
      logsList.insertBefore(newLog, logsList.firstChild);
      
      if (logsList.children.length > 5) {
        logsList.removeChild(logsList.lastChild);
      }
    }
  };

  // Run update loop every 3 seconds
  setInterval(updateDashboard, 3000);
</script>

<style>
  .dashboard-card {
    padding: 0; /* Remove padding to handle header styled bounds */
    display: flex;
    flex-direction: column;
    width: 100%;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-lg);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .dashboard-topbar {
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-color);
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dash-window-buttons {
    display: flex;
    gap: 6px;
  }

  .dash-window-buttons span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .dash-window-buttons span:nth-child(1) { background-color: #ff5f56; }
  .dash-window-buttons span:nth-child(2) { background-color: #ffbd2e; }
  .dash-window-buttons span:nth-child(3) { background-color: #27c93f; }

  .dash-window-title {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .dash-live-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent-color);
    letter-spacing: 0.05em;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--accent-color);
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 480px;
  }

  /* Sidebar styling */
  .dash-sidebar {
    background: rgba(0, 0, 0, 0.02);
    border-right: 1px solid var(--border-color);
    padding: 1.5rem;
  }

  :global(.dark) .dash-sidebar {
    background: rgba(255, 255, 255, 0.01);
  }

  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }

  .sidebar-header h4 {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .count-badge {
    font-size: 0.75rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
  }

  .monitor-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .monitor-item {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: transform var(--transition-fast);
  }

  .monitor-item:hover {
    transform: translateX(4px);
    border-color: var(--border-glow);
  }

  .monitor-status-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }

  .indicator.green {
    background-color: var(--success);
    box-shadow: 0 0 8px var(--success);
  }

  .monitor-meta {
    display: flex;
    flex-direction: column;
  }

  .monitor-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .monitor-details {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .monitor-stats {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .latency {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--text-secondary);
    font-weight: 500;
  }

  .uptime {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  /* Main preview styling */
  .dash-main {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .stats-overview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat-box {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .stat-sub {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .stat-sub.green {
    color: var(--success);
  }

  /* Chart Container */
  .chart-container {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 1.5rem;
  }

  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }

  .chart-header h5 {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .chart-legend {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .bg-accent {
    background-color: var(--accent-color);
  }

  .chart-svg-wrapper {
    width: 100%;
  }

  .chart-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* Resource Gauges */
  .resources-container {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
  }

  .resources-container h5 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1.2rem;
  }

  .gauges-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .gauge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .gauge-ring-wrapper {
    position: relative;
    width: 90px;
    height: 90px;
  }

  .gauge-svg {
    transform: rotate(-90deg);
    width: 100%;
    height: 100%;
  }

  .gauge-bg {
    fill: none;
    stroke: var(--border-color);
    stroke-width: 8;
  }

  .gauge-fill {
    fill: none;
    stroke: var(--accent-color);
    stroke-width: 8;
    stroke-linecap: round;
    transition: stroke-dashoffset var(--transition-slow) ease-out;
  }

  .gauge-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .gauge-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  /* Audit Log Scroller */
  .event-log {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
  }

  .event-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .event-header h5 {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .status-indicator-log {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--success);
    font-weight: 600;
  }

  .green-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--success);
  }

  .event-scroller {
    max-height: 150px;
    overflow-y: auto;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 1rem;
  }

  .event-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .event-log-item {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .log-time {
    color: var(--text-muted);
    min-width: 65px;
  }

  .log-tag {
    font-weight: 800;
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-transform: uppercase;
  }

  .log-tag.tag-success {
    background-color: var(--success-bg);
    color: var(--success);
  }

  /* Responsiveness */
  @media (max-width: 992px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
    .dash-sidebar {
      border-right: none;
      border-bottom: 1px solid var(--border-color);
    }
  }

  @media (max-width: 600px) {
    .stats-overview-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
