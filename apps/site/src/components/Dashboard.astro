---
// Dashboard.astro - Live status preview, fetched from the real status API.
// Previously this was 100% fabricated (fake monitor names/domains, a randomly
// animated latency chart, fake CPU/RAM/disk gauges for a "Central Server" we
// have no honest way to expose, and a fake incident log). All of that is gone.
// What's left only shows numbers the public status API actually returns -
// individual monitor names are intentionally never exposed here, matching the
// privacy convention used by the distributed probe agents themselves.
const currentPath = Astro.url.pathname;
const isCs = currentPath.startsWith('/cs') || currentPath === '/cs';

const t = isCs ? {
  windowTitle: 'blood-kings-monitoring — živý stav',
  live: 'ŽIVĚ',
  unavailable: 'NEDOSTUPNÉ',
  nodesTitle: 'Distribuovaní agenti',
  nodesEmpty: 'Zatím žádní distribuovaní agenti',
  totalUptime: 'Dostupnost (30 dní)',
  avgLatency: 'Průměrná latence',
  monitors: 'Monitorů',
  agents: 'Agentů online',
  allOperational: 'Všechny systémy v pořádku',
  degraded: 'Některé systémy mají výpadek',
  loadError: 'Živá data se nepodařilo načíst. Toto je self-hosted aplikace - vidíte přesně to, co vidí i majitel.',
} : {
  windowTitle: 'blood-kings-monitoring — live status',
  live: 'LIVE',
  unavailable: 'UNAVAILABLE',
  nodesTitle: 'Distributed Agents',
  nodesEmpty: 'No distributed agents yet',
  totalUptime: 'Uptime (30 days)',
  avgLatency: 'Average Latency',
  monitors: 'Monitors',
  agents: 'Agents Online',
  allOperational: 'All systems operational',
  degraded: 'Some systems are degraded',
  loadError: "Couldn't load live data. This is a self-hosted app - you're seeing exactly what the owner sees.",
};
---

<div class="dashboard-card card card-glow" id="live-dashboard-card">
  <div class="dashboard-topbar">
    <div class="dash-window-buttons">
      <span></span><span></span><span></span>
    </div>
    <div class="dash-window-title">{t.windowTitle}</div>
    <div class="dash-live-badge" id="dash-live-badge">
      <span class="live-dot pulse"></span>
      {t.live}
    </div>
  </div>

  <div class="dashboard-grid">
    <aside class="dash-sidebar">
      <div class="sidebar-header">
        <h4>{t.nodesTitle}</h4>
        <span class="count-badge" id="dash-nodes-count">—</span>
      </div>
      <ul class="monitor-list" id="dash-nodes-list" data-empty={t.nodesEmpty}>
        <li class="monitor-item-status">···</li>
      </ul>
    </aside>

    <section class="dash-main">
      <div class="dash-status-line" id="dash-status-line">···</div>

      <div class="stats-overview-grid">
        <div class="stat-box">
          <span class="stat-title">{t.totalUptime}</span>
          <span class="stat-value text-gradient" id="dash-uptime">—</span>
        </div>
        <div class="stat-box">
          <span class="stat-title">{t.avgLatency}</span>
          <span class="stat-value" id="dash-latency">—</span>
        </div>
        <div class="stat-box">
          <span class="stat-title">{t.monitors}</span>
          <span class="stat-value" id="dash-monitors">—</span>
        </div>
        <div class="stat-box">
          <span class="stat-title">{t.agents}</span>
          <span class="stat-value" id="dash-agents">—</span>
        </div>
      </div>
    </section>
  </div>
</div>

<script define:vars={{ allOperational: t.allOperational, degraded: t.degraded, loadError: t.loadError, nodesEmpty: t.nodesEmpty, unavailable: t.unavailable, live: t.live }}>
  async function loadLiveDashboard() {
    const badge = document.getElementById('dash-live-badge');
    const statusLine = document.getElementById('dash-status-line');
    const nodesList = document.getElementById('dash-nodes-list');
    const nodesCount = document.getElementById('dash-nodes-count');
    const uptimeEl = document.getElementById('dash-uptime');
    const latencyEl = document.getElementById('dash-latency');
    const monitorsEl = document.getElementById('dash-monitors');
    const agentsEl = document.getElementById('dash-agents');

    let apiOrigin = window.location.origin;
    if (apiOrigin.includes('localhost') || apiOrigin.includes('127.0.0.1')) {
      apiOrigin = 'https://monitoring.bloodkings.eu';
    }

    try {
      const res = await fetch(`${apiOrigin}/api/status`);
      if (!res.ok) throw new Error('unavailable');
      const data = await res.json();
      if (data.available === false) throw new Error('unavailable');

      if (statusLine) {
        statusLine.textContent = data.status === 'degraded' ? degraded : allOperational;
        statusLine.className = 'dash-status-line ' + (data.status === 'degraded' ? 'status-degraded' : 'status-ok');
      }
      if (uptimeEl) uptimeEl.textContent = `${Number(data.uptimePercent ?? 0).toFixed(2)}%`;
      if (latencyEl) latencyEl.textContent = `${data.avgLatencyMs ?? 0} ms`;
      if (monitorsEl) monitorsEl.textContent = `${data.totalMonitors ?? 0}`;
      if (agentsEl) agentsEl.textContent = `${data.agentsOnline ?? 0} / ${data.agentsTotal ?? 0}`;

      const nodes = Array.isArray(data.nodes) ? data.nodes : [];
      if (nodesCount) nodesCount.textContent = `${nodes.length}`;
      if (nodesList) {
        if (nodes.length === 0) {
          nodesList.innerHTML = `<li class="monitor-item-status">${nodesEmpty}</li>`;
        } else {
          nodesList.innerHTML = nodes.slice(0, 6).map((n) => {
            const safeName = String(n.name ?? '').replace(/[<>&]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[c]));
            const latency = typeof n.latencyMs === 'number' ? `${n.latencyMs} ms` : '';
            return `
              <li class="monitor-item">
                <div class="monitor-status-info">
                  <span class="indicator ${n.status === 'online' ? 'green' : (n.status === 'warning' ? 'yellow' : 'red')}"></span>
                  <div class="monitor-meta">
                    <span class="monitor-name">${safeName}</span>
                  </div>
                </div>
                <div class="monitor-stats">
                  <span class="latency">${latency}</span>
                </div>
              </li>
            `;
          }).join('');
        }
      }
    } catch (e) {
      if (badge) {
        badge.innerHTML = `<span class="live-dot offline"></span>${unavailable}`;
      }
      if (statusLine) {
        statusLine.textContent = loadError;
        statusLine.className = 'dash-status-line status-unavailable';
      }
      if (nodesList) nodesList.innerHTML = `<li class="monitor-item-status">${unavailable}</li>`;
    }
  }

  loadLiveDashboard();
  setInterval(loadLiveDashboard, 60000);
</script>

<style>
  .dashboard-card {
    padding: 0;
    display: flex;
    flex-direction: column;
    width: 100%;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-lg);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .dashboard-topbar {
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-color);
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dash-window-buttons {
    display: flex;
    gap: 6px;
  }

  .dash-window-buttons span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .dash-window-buttons span:nth-child(1) { background-color: #ff5f56; }
  .dash-window-buttons span:nth-child(2) { background-color: #ffbd2e; }
  .dash-window-buttons span:nth-child(3) { background-color: #27c93f; }

  .dash-window-title {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .dash-live-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent-color);
    letter-spacing: 0.05em;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--accent-color);
  }

  .live-dot.offline {
    background-color: var(--text-muted);
    animation: none;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 320px;
  }

  .dash-sidebar {
    background: rgba(0, 0, 0, 0.02);
    border-right: 1px solid var(--border-color);
    padding: 1.5rem;
  }

  :global(.dark) .dash-sidebar {
    background: rgba(255, 255, 255, 0.01);
  }

  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }

  .sidebar-header h4 {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .count-badge {
    font-size: 0.75rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
  }

  .monitor-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .monitor-item-status {
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .monitor-item {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .monitor-status-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  .indicator.green { background-color: var(--success); box-shadow: 0 0 8px var(--success); }
  .indicator.yellow { background-color: var(--warning); box-shadow: 0 0 8px var(--warning); }
  .indicator.red { background-color: var(--danger); box-shadow: 0 0 8px var(--danger); }

  .monitor-meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .monitor-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .latency {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }

  .dash-main {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .dash-status-line {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .dash-status-line.status-ok { color: var(--success); }
  .dash-status-line.status-degraded { color: var(--danger); }
  .dash-status-line.status-unavailable { color: var(--text-muted); font-weight: 500; font-size: 0.85rem; }

  .stats-overview-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .stat-box {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.1;
  }

  @media (max-width: 992px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
    .dash-sidebar {
      border-right: none;
      border-bottom: 1px solid var(--border-color);
    }
  }

  @media (max-width: 600px) {
    .stats-overview-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .dash-main {
      padding: 1.2rem;
    }
  }
</style>
