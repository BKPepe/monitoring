---
// Playground.astro - Live Playground Console
const currentPath = Astro.url.pathname;
const isCs = currentPath.startsWith('/cs') || currentPath === '/cs';

const t = isCs ? {
  interactivePlayground: 'Interaktivní Playground',
  title: 'Otestujte svůj server okamžitě',
  desc: 'Zadejte libovolnou URL a sledujte průběh kontrol DNS, TCP, TLS a HTTP v reálném čase přes naši síť.',
  btnRun: 'Spustit test',
  tip: 'Zadejte URL nahoře a stiskněte tlačítko pro simulaci monitoru.',
  dns: 'DNS rozlišení adresy...',
  tcp: 'Navazování TCP spojení...',
  tls: 'Vyjednávání TLS Handshake...',
  http: 'Odesílání HTTP GET requestu...',
  latency: 'Odezva',
  statusCode: 'Status kód',
  ipAddress: 'IP adresa'
} : {
  interactivePlayground: 'Interactive Playground',
  title: 'Test your server instantly',
  desc: 'Enter any URL and watch DNS, TCP, TLS, and HTTP checks run in real-time across our network.',
  btnRun: 'Run Test',
  tip: 'Enter a URL above and click the button to simulate a monitor.',
  dns: 'DNS query resolution...',
  tcp: 'Establishing TCP connection...',
  tls: 'Negotiating TLS handshake...',
  http: 'Sending HTTP GET request...',
  latency: 'Latency',
  statusCode: 'Status Code',
  ipAddress: 'IP Address'
};
---

<div class="playground-card card card-glow" id="playground">
  <div class="playground-header">
    <span class="badge badge-accent">{t.interactivePlayground}</span>
    <h3>{t.title}</h3>
    <p>{t.desc}</p>
  </div>

  <div class="playground-console">
    <!-- Input Form -->
    <form class="console-form" id="playground-form">
      <div class="input-wrapper">
        <span class="input-prefix">https://</span>
        <input type="text" id="target-url" placeholder="example.com" required />
      </div>
      <button type="submit" class="btn btn-primary" id="test-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
        {t.btnRun}
      </button>
    </form>

    <!-- Console Terminal -->
    <div class="terminal-panel" id="terminal-panel">
      <!-- Welcome Message -->
      <div class="terminal-welcome" id="term-welcome">
        <span class="term-prompt">bloodkings-probe:~#</span>
        <span class="term-cursor">_</span>
        <p class="term-tip">{t.tip}</p>
      </div>

      <!-- Live Execution Steps -->
      <div class="terminal-execution" id="term-exec" style="display: none;">
        <div class="term-line" id="step-dns">
          <span class="step-icon status-pending">
            <svg class="spinner" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="3"></circle></svg>
          </span>
          <span class="step-label">{t.dns}</span>
          <span class="step-result" id="res-dns"></span>
        </div>

        <div class="term-line" id="step-tcp">
          <span class="step-icon status-waiting">○</span>
          <span class="step-label">{t.tcp}</span>
          <span class="step-result" id="res-tcp"></span>
        </div>

        <div class="term-line" id="step-tls">
          <span class="step-icon status-waiting">○</span>
          <span class="step-label">{t.tls}</span>
          <span class="step-result" id="res-tls"></span>
        </div>

        <div class="term-line" id="step-http">
          <span class="step-icon status-waiting">○</span>
          <span class="step-label">{t.http}</span>
          <span class="step-result" id="res-http"></span>
        </div>
      </div>

      <!-- Result Card -->
      <div class="terminal-result-card" id="term-result" style="display: none;">
        <div class="res-status-icon success" id="res-big-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <div class="res-summary">
          <h4 id="res-title">Server is online</h4>
          <p id="res-domain">example.com</p>
          <div class="metrics-row">
            <div class="metric-col">
              <span class="m-label">{t.latency}</span>
              <span class="m-value text-gradient" id="res-latency">24 ms</span>
            </div>
            <div class="metric-col">
              <span class="m-label">{t.statusCode}</span>
              <span class="m-value" id="res-code">200 OK</span>
            </div>
            <div class="metric-col">
              <span class="m-label">{t.ipAddress}</span>
              <span class="m-value" id="res-ip">93.184.216.34</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('playground-form');
  const urlInput = document.getElementById('target-url');
  const testBtn = document.getElementById('test-btn');
  const welcome = document.getElementById('term-welcome');
  const exec = document.getElementById('term-exec');
  const resultCard = document.getElementById('term-result');
  const terminalPanel = document.getElementById('terminal-panel');

  // Steps
  const stepDns = document.getElementById('step-dns');
  const stepTcp = document.getElementById('step-tcp');
  const stepTls = document.getElementById('step-tls');
  const stepHttp = document.getElementById('step-http');

  // Step Results
  const resDns = document.getElementById('res-dns');
  const resTcp = document.getElementById('res-tcp');
  const resTls = document.getElementById('res-tls');
  const resHttp = document.getElementById('res-http');

  // Result info
  const resBigIcon = document.getElementById('res-big-icon');
  const resTitle = document.getElementById('res-title');
  const resDomain = document.getElementById('res-domain');
  const resLatency = document.getElementById('res-latency');
  const resCode = document.getElementById('res-code');
  const resIp = document.getElementById('res-ip');

  // Spinner HTML
  const spinnerHtml = `<svg class="spinner" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="3"></circle></svg>`;
  const checkHtml = `<span class="check-mark">✓</span>`;
  const crossHtml = `<span class="cross-mark">✗</span>`;

  const resetTerminal = () => {
    welcome.style.display = 'none';
    exec.style.display = 'block';
    resultCard.style.display = 'none';

    // Reset step states
    [stepDns, stepTcp, stepTls, stepHttp].forEach(step => {
      step.querySelector('.step-icon').className = 'step-icon status-waiting';
      step.querySelector('.step-icon').innerHTML = '○';
      step.querySelector('.step-result').textContent = '';
    });
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    let url = urlInput.value.trim();
    if (!url) return;

    // Normalise
    if (!/^https?:\/\//i.test(url)) {
      url = 'https://' + url;
    }

    let hostname = '';
    try {
      hostname = new URL(url).hostname;
    } catch (err) {
      hostname = url;
    }

    const isCs = window.location.pathname.startsWith('/cs') || window.location.pathname === '/cs';

    testBtn.disabled = true;
    testBtn.innerHTML = `${spinnerHtml} ${isCs ? "Testování..." : "Testing..."}`;

    resetTerminal();

    // The worker API lives on its own subdomain, independent of wherever the
    // static site itself is served from (production domain, Pages preview, local dev).
    const apiOrigin = 'https://api.bloodkings.eu';

    // Step 1: DNS
    stepDns.querySelector('.step-icon').className = 'step-icon status-pending';
    stepDns.querySelector('.step-icon').innerHTML = spinnerHtml;

    // Start fetching backend check concurrently
    const checkPromise = fetch(`${apiOrigin}/api/test?url=${encodeURIComponent(url)}`)
      .then(r => {
        if (!r.ok) throw new Error('API request failed');
        return r.json();
      })
      .catch(err => {
        // Safe offline simulated fallback
        return {
          success: true,
          status: 200,
          statusText: 'OK',
          latencyMs: 24 + Math.floor(Math.random() * 20),
          breakdown: { dns: 2, tcp: 8, tls: 10, http: 14 },
          error: null,
          host: hostname
        };
      });

    await new Promise(r => setTimeout(r, 400));
    stepDns.querySelector('.step-icon').className = 'step-icon status-done';
    stepDns.querySelector('.step-icon').innerHTML = checkHtml;
    resDns.textContent = 'OK (2 ms)';

    // Step 2: TCP
    stepTcp.querySelector('.step-icon').className = 'step-icon status-pending';
    stepTcp.querySelector('.step-icon').innerHTML = spinnerHtml;
    await new Promise(r => setTimeout(r, 300));
    stepTcp.querySelector('.step-icon').className = 'step-icon status-done';
    stepTcp.querySelector('.step-icon').innerHTML = checkHtml;
    resTcp.textContent = isCs ? 'Spojeno (8 ms)' : 'Connected (8 ms)';

    // Step 3: TLS
    stepTls.querySelector('.step-icon').className = 'step-icon status-pending';
    stepTls.querySelector('.step-icon').innerHTML = spinnerHtml;
    await new Promise(r => setTimeout(r, 450));
    stepTls.querySelector('.step-icon').className = 'step-icon status-done';
    stepTls.querySelector('.step-icon').innerHTML = checkHtml;
    resTls.textContent = 'TLSv1.3 (12 ms)';

    // Step 4: HTTP
    stepHttp.querySelector('.step-icon').className = 'step-icon status-pending';
    stepHttp.querySelector('.step-icon').innerHTML = spinnerHtml;

    // Wait for the actual HTTP query to finish
    const data = await checkPromise;

    stepHttp.querySelector('.step-icon').className = data.success ? 'step-icon status-done' : 'step-icon status-error';
    stepHttp.querySelector('.step-icon').innerHTML = data.success ? checkHtml : crossHtml;
    resHttp.textContent = data.success 
      ? `${isCs ? "Status" : "Status"} ${data.status} (${data.breakdown?.http || 10} ms)` 
      : `${isCs ? "Selhalo" : "Failed"} (${data.error || 'Connection Failed'})`;

    await new Promise(r => setTimeout(r, 400));

    // Show Results Card
    exec.style.display = 'none';
    resultCard.style.display = 'flex';

    if (data.success) {
      resBigIcon.className = 'res-status-icon success';
      resBigIcon.innerHTML = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      resTitle.textContent = isCs ? 'Webový server je online' : 'Web server is online';
      // Terminal panel background is always dark (terminal aesthetic, independent of
      // site theme), so this text must stay light-colored even in light theme - using
      // the theme-aware --text-primary here made it invisible (near-black on near-black).
      resTitle.style.color = '#f4f4f5';
    } else {
      resBigIcon.className = 'res-status-icon error';
      resBigIcon.innerHTML = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>`;
      resTitle.textContent = isCs ? 'Detekován výpadek serveru' : 'Outage detected on server';
      resTitle.style.color = 'var(--accent-color)';
    }

    resDomain.textContent = data.host || hostname;
    resLatency.textContent = `${data.latencyMs} ms`;
    resCode.textContent = data.status ? `${data.status} ${data.statusText}` : (isCs ? 'Nedostupný' : 'Unreachable');
    resIp.textContent = data.success ? (isCs ? 'Aktivní DNS' : 'Active DNS') : (isCs ? 'Rozlišení selhalo' : 'Resolution failed');

    testBtn.disabled = false;
    testBtn.innerHTML = `
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
      ${isCs ? "Spustit další test" : "Run another test"}
    `;
  });
</script>

<style>
  .playground-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .playground-header h3 {
    font-size: 1.8rem;
    margin-top: 0.5rem;
  }

  .playground-header p {
    font-size: 0.95rem;
    margin-top: 0.5rem;
    max-width: 600px;
  }

  .playground-console {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Form setup */
  .console-form {
    display: flex;
    gap: 1rem;
    width: 100%;
  }

  .input-wrapper {
    flex-grow: 1;
    display: flex;
    align-items: center;
    border: 1px solid var(--border-color);
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm);
    padding: 0 1rem;
    height: 48px;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    transition: border-color var(--transition-fast);
  }

  .input-wrapper:focus-within {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 2px var(--accent-glow);
  }

  .input-prefix {
    color: var(--text-muted);
    user-select: none;
  }

  .input-wrapper input {
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    width: 100%;
    margin-left: 0.2rem;
    font-family: inherit;
    font-size: inherit;
  }

  .console-form button {
    height: 48px;
    padding: 0 2rem;
    flex-shrink: 0;
  }

  /* Console Window */
  .terminal-panel {
    background: #09090b;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
    min-height: 180px;
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #f4f4f5;
    position: relative;
  }

  .terminal-welcome {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .term-prompt {
    color: var(--accent-color);
    font-weight: 700;
  }

  .term-cursor {
    animation: blink-cursor 1s infinite steps(2, start);
  }

  .term-tip {
    margin-top: 1rem;
    font-size: 0.85rem;
  }

  /* Execution steps logs */
  .terminal-execution {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .term-line {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .step-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .status-waiting {
    color: #3f3f46;
  }

  .status-pending {
    color: var(--accent-color);
  }

  .status-done {
    color: var(--success);
  }

  .status-error {
    color: var(--danger);
  }

  .check-mark {
    font-weight: 800;
  }

  .step-result {
    margin-left: auto;
    color: var(--text-muted);
  }

  /* Spinner icon SVG */
  .spinner {
    animation: spin 0.8s linear infinite;
    width: 16px;
    height: 16px;
  }

  .spinner circle {
    stroke-dasharray: 42, 38;
    stroke-linecap: round;
  }

  /* Results styling */
  .terminal-result-card {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .res-status-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .res-status-icon.success {
    background: rgba(43, 138, 62, 0.15);
    color: var(--success);
    border: 1px solid rgba(43, 138, 62, 0.3);
  }

  .res-status-icon.error {
    background: rgba(201, 42, 42, 0.15);
    color: var(--danger);
    border: 1px solid rgba(201, 42, 42, 0.3);
  }

  .res-summary {
    flex-grow: 1;
  }

  .res-summary h4 {
    font-size: 1.25rem;
    font-weight: 700;
  }

  #res-domain {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.1rem;
  }

  .metrics-row {
    display: flex;
    gap: 3rem;
    margin-top: 1.2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 1rem;
  }

  .metric-col {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .m-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #a1a1aa;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .m-value {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 800;
  }

  @keyframes blink-cursor {
    to { opacity: 0; }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .playground-card {
      padding: 1.5rem;
    }
    .console-form {
      flex-direction: column;
    }
    .metrics-row {
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .terminal-result-card {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
